{
  "version": "1.0",
  "name": "While Loop Review",
  "nodes": [
    {
      "id": "input-1",
      "type": "input_node",
      "position": { "x": 40, "y": 220 },
      "config": {
        "name": "user_input",
        "description": "Initial draft or prompt to review."
      }
    },
    {
      "id": "while-review",
      "type": "while_node",
      "position": { "x": 260, "y": 70 },
      "width": 460,
      "height": 320,
      "config": {
        "condition": "!('review_draft' in state) || state.review_draft.review_status != 'approved'",
        "max_iterations": 4
      }
    },
    {
      "id": "review-draft",
      "type": "llm_node",
      "position": { "x": 36, "y": 112 },
      "parent_id": "while-review",
      "config": {
        "name": "review_draft",
        "description": "Review and rewrite until the draft is approved.",
        "model": "gemini-2.5-flash",
        "instruction": "Review the current draft. Return JSON with review_status ('approved' or 'revise'), revised_prompt, and reviewer_notes. Use the user's original message on the first pass and your own latest revision on later passes.",
        "response_mode": "json",
        "output_schema": {
          "type": "object",
          "properties": {
            "review_status": { "type": "string" },
            "revised_prompt": { "type": "string" },
            "reviewer_notes": { "type": "string" }
          },
          "required": ["review_status", "revised_prompt", "reviewer_notes"]
        },
        "generate_content_config": {
          "temperature": 0.2,
          "max_output_tokens": 768
        }
      }
    },
    {
      "id": "finalize",
      "type": "llm_node",
      "position": { "x": 840, "y": 160 },
      "config": {
        "name": "finalize_result",
        "description": "Summarize the final approved result.",
        "model": "gemini-2.5-flash",
        "instruction": "Using state.review_draft, present the approved prompt and briefly summarize the review outcome.",
        "response_mode": "text",
        "generate_content_config": {
          "temperature": 0.1,
          "max_output_tokens": 512
        }
      }
    },
    {
      "id": "output-1",
      "type": "output_node",
      "position": { "x": 1160, "y": 160 },
      "config": {
        "name": "final_output",
        "output_key": "result",
        "format": "message"
      }
    }
  ],
  "edges": [
    {
      "id": "e-input-loop",
      "source": "input-1",
      "source_port": "message:out",
      "target": "while-review",
      "target_port": "message:enter",
      "data_type": "message",
      "edge_kind": "data_flow"
    },
    {
      "id": "e-loop-review",
      "source": "while-review",
      "source_port": "message:loop",
      "target": "review-draft",
      "target_port": "message:in",
      "data_type": "message",
      "edge_kind": "data_flow"
    },
    {
      "id": "e-review-return",
      "source": "review-draft",
      "source_port": "message:out",
      "target": "while-review",
      "target_port": "message:return",
      "data_type": "message",
      "edge_kind": "data_flow"
    },
    {
      "id": "e-loop-finalize",
      "source": "while-review",
      "source_port": "message:done",
      "target": "finalize",
      "target_port": "message:in",
      "data_type": "message",
      "edge_kind": "data_flow"
    },
    {
      "id": "e-finalize-output",
      "source": "finalize",
      "source_port": "message:out",
      "target": "output-1",
      "target_port": "message:in",
      "data_type": "message",
      "edge_kind": "data_flow"
    }
  ]
}
