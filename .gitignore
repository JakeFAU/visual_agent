# Monorepo .gitignore for Visual Agent

# General
.DS_Store
*.log
.env
.env.local
.env.*.local

# Security & Credentials
.google-cloud/
adc.json
credentials.json
keyfile.json
*.pem
*.key

# Front-end (React/Vite/Node)
front_end/node_modules/
front_end/dist/
front_end/build/
front_end/.vite/
front_end/npm-debug.log*
front_end/yarn-debug.log*
front_end/yarn-error.log*

# Back-end (Go)
back_end/bin/
back_end/dist/
back_end/vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
back_end/*.test
back_end/*.out
back_end/visual-agent
back_end/data/graphs/*.json

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Temporary Files
tmp/
.gemini/tmp/
docs/
GEMINI.md
